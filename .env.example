# ── WhatsApp Business Cloud API (Meta) ─────────────────────────────
# Get these from https://developers.facebook.com > your app > WhatsApp > API Setup
WHATSAPP_TOKEN=your_permanent_access_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id_here

# ── Webhook ─────────────────────────────────────────────────────────
# Choose any random string — paste the same value in Meta's webhook config
WEBHOOK_VERIFY_TOKEN=my_super_secret_verify_token

# ── Server ──────────────────────────────────────────────────────────
PORT=4000
FRONTEND_URL=http://localhost:4200
